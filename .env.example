# Google Sheets Configuration
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json
GOOGLE_SHEET_ID=your_sheet_id_here

# ICP Filter Settings
MIN_FUNDING_AMOUNT=5000000
FUNDING_LOOKBACK_DAYS=30

# Locations to target (comma-separated)
TARGET_LOCATIONS=San Francisco,New York,London,Berlin,Paris,Amsterdam,Remote

# AI Keywords for filtering (comma-separated)
AI_KEYWORDS=artificial intelligence,machine learning,AI,ML,deep learning,LLM,GPT,neural network,computer vision,NLP

# Rate Limiting
REQUEST_DELAY_SECONDS=2

# Optional: Slack webhook for notifications
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_TRIGGER_CHANNEL_ID=
DASHBOARD_URL=

# Optional: Email notifications
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=
